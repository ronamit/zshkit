simplified_ui true
pane_frames false
scroll_buffer_size 100000
serialize_pane_viewport true
scrollback_lines_to_serialize 100000
show_startup_tips false
show_release_notes false

// Copy/paste: keep selection visible after mouse release; copy explicitly with Enter or y.
// copy_on_select true would auto-copy and immediately clear the selection, which causes
// "select all" (e.g. in VSCode terminal) to flash and disappear.
// No copy_command is set — Zellij uses OSC 52 by default, which works both
// locally and over SSH (as long as your local terminal supports OSC 52,
// e.g. Ghostty, Kitty, WezTerm, Alacritty, iTerm2).
copy_on_select false

// Mouse: Zellij captures mouse events for pane focus, scroll, and border drag-resize.
// TRADE-OFF: because Zellij owns the mouse, native terminal text selection requires
// holding Shift while dragging. This is an architectural Zellij limitation — there is
// no config option to get plain drag-select while keeping mouse scroll. Tmux has the
// same constraint. The only escape is switching to a terminal's native splits (e.g.
// Ghostty splits), which sacrifices session persistence.
// → To select text: hold Shift + drag.
// → To copy: release, then Enter or y (copy_on_select is false — see above).
advanced_mouse_actions true

__SCROLLBACK_EDITOR_LINE__

// zellij-attention: adds ⏳/✅ icons to tab names when Claude Code needs input or finishes.
// Icons clear automatically when you focus the pane.
load_plugins {
    "file:~/.config/zellij/plugins/zellij-attention.wasm" {
        waiting_icon "⏳"
        completed_icon "✅"
    }
}
