simplified_ui true
pane_frames false
scroll_buffer_size 100000
// serialize_pane_viewport is intentionally disabled. When enabled, Zellij
// saves pane scrollback to disk and restores it on next attach — including
// after a remote reboot. This makes reconnecting after a reboot look like
// the old session (with stuck processes) is still running, which is confusing.
// To enable session resurrection, uncomment the two lines below:
// serialize_pane_viewport true
// scrollback_lines_to_serialize 100000
show_startup_tips false
show_release_notes false

// Copy/paste: keep selection visible after mouse release; copy explicitly with Enter or y.
// copy_on_select true would auto-copy and immediately clear the selection, which causes
// "select all" (e.g. in VSCode terminal) to flash and disappear.
// No copy_command is set — Zellij uses OSC 52 by default, which works both
// locally and over SSH (as long as your local terminal supports OSC 52,
// e.g. Ghostty, WezTerm, Alacritty, iTerm2, Kitty).
copy_on_select false

// mouse_mode is kept true (the Zellij default). Setting it to false breaks mouse scroll
// entirely — the terminal prints raw escape codes instead of scrolling. The trade-off is
// that native terminal text selection requires holding Shift while dragging.
// → To select text: Shift+drag. To copy: release, then Enter or y.
mouse_mode true

// advanced_mouse_actions: adds pane border drag-resize and Ctrl+ScrollWheel pane resize
// on top of the base mouse_mode capture.
advanced_mouse_actions true

__SCROLLBACK_EDITOR_LINE__

// Muted theme: tones down the active-tab highlight from the default bright green
// to a dim slate-blue. Only the colors used by the built-in tab-bar matter here.
themes {
    zshkit {
        fg 200 200 200
        bg 22 22 26
        black 22 22 26
        red 180 80 80
        green 72 110 140
        yellow 190 170 80
        blue 80 110 180
        magenta 140 80 160
        cyan 70 150 160
        white 210 210 210
        orange 200 130 70
    }
}
theme "zshkit"

// zellij-attention: adds ⏳/✅ icons to tab names when Claude Code needs input or finishes.
// Icons clear automatically when you focus the pane.
load_plugins {
    "file:~/.config/zellij/plugins/zellij-attention.wasm" {
        waiting_icon "⏳"
        completed_icon "✅"
    }
}
