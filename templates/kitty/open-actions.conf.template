# open-actions.conf — zshkit starter config
# Make Kitty hyperlinks from tools like rg open in your editor instead of the OS file browser.

protocol file
fragment_matches [0-9]+
action launch --type=overlay --cwd=current -- micro +${FRAGMENT} -- ${FILE_PATH}

protocol file
mime text/*
action launch --type=overlay --cwd=current -- micro -- ${FILE_PATH}
