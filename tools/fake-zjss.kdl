layout {
    default_tab_template { children; }
    tab {
        pane split_direction="vertical" {
            pane split_direction="horizontal" { command "zsh"; args "-c" "echo 'gpu-server | Session 0'; sleep infinity"; }
            pane split_direction="horizontal" { command "zsh"; args "-c" "echo 'gpu-server | Session 2'; sleep infinity"; }
        }
        pane split_direction="vertical" {
            pane split_direction="horizontal" { command "zsh"; args "-c" "echo 'gpu-server | Session 1'; sleep infinity"; }
            pane split_direction="horizontal" { command "zsh"; args "-c" "echo 'gpu-server | Session 3'; sleep infinity"; }
        }
    }
}
