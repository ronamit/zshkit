{
    "workbench.iconTheme": "vscode-great-icons",
    "workbench.activityBar.orientation": "horizontal",
    "workbench.list.openMode": "doubleClick",
    "window.commandCenter": true,
    "window.title": "${dirty}${separator}${rootName}${separator}${activeEditorShort}",
    "editor.fontFamily": "MesloLGS NF",
    "editor.fontSize": 14,
    "editor.lineHeight": 21,
    "editor.minimap.enabled": false,
    "editor.inlineSuggest.enabled": true,
    "workbench.editorAssociations": {
        "*.csv": "csv.editor"
    },
    "workbench.colorCustomizations": {
        "tab.activeBorder": "#007ACC",
        "tab.activeBorderTop": "#007ACC",
        "tab.activeBackground": "#1E1E1E",
        "tab.activeForeground": "#FFFFFF",
        "activityBar.activeBackground": "#1E1E1E",
        "activityBar.activeBorder": "#007ACC",
        "activityBar.activeForeground": "#FFFFFF",
        "list.warningForeground": "#ffffff",
        "terminal.integrated.detectUrls": true,
        "terminal.linkForeground": "#00ff00",
        "terminal.linkActiveForeground": "#ff0000",
        "terminal.linkActiveBackground": "#2a2a2a",
        "terminal.linkActiveBorder": "#ff0000",
        "terminal.foreground": "#ffffff",
        "terminal.ansiBlue": "#3794ff"
    },

    // ========================================
    // Terminal
    // ========================================
    "terminal.integrated.shellIntegration.enabled": false, // #1 fix for SSH hangs
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.fontFamily": "Hack Nerd Font",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.sendKeybindingsToShell": true,

    // ========================================
    // Files & Exclusions
    // ========================================
    "files.autoSave": "afterDelay",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.DS_Store": true,
        "**/*.egg-info": true,
        "**/.ruff_cache": true,
        "**/.mypy_cache": true,
        "**/dist": true
    },
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,

    // ========================================
    // Cursor & AI Features
    // ========================================
    "cursor.terminal.usePreviewBox": false,
    "cursor.composer.queueMessageDefaultBehavior": "queue",
    "cursor.composer.usageSummaryDisplay": "always",
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "cursor.cpp.disabledLanguages": [
        "plaintext"
    ],

    // ========================================
    // Python & Linters
    // ========================================
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "ruff.lint.ignore": ["W293", "E402", "D102", "D103", "D413"],
    "cursorpyright.analysis.autoImportCompletions": false,
    "cursorpyright.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none"
    },
    "debugpy.debugJustMyCode": false,

    // ========================================
    // Git & GitLens
    // ========================================
    "git.autofetch": true,
    "gitlens.plusFeatures.enabled": false,
    "gitlens.currentLine.enabled": false,
    "gitlens.currentLine.scrollable": false,
    "gitlens.codeLens.authors.command": false,
    "gitlens.ai.enabled": false,
    "gitlens.integrations.enabled": false,
    "gitlens.cloudPatches.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": true,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "fileHistory": false,
        "repositories": true,
        "searchAndCompare": true,
        "launchpad": false
    },

    // ========================================
    // Remote / SSH
    // ========================================
    "remote.SSH.connectTimeout": 60,
    "remote.autoForwardPortsSource": "hybrid",
    "remote.SSH.remotePlatform": {
        "ai-researcher-dev-rona": "linux",
        "ubuntu-desktop": "linux"
    },

    // ========================================
    // Spell Checker Dictionary
